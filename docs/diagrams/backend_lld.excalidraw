    {
      "type": "text",
      "id": "file_flow_legend_body",
      "x": 692, "y": 716,
      "width": 256, "height": 190,
      "text": "1. POST /files/upload (multipart)\n2. JWT middleware validates token\n3. File saved → uploads/{uid}/\n4. FileHandler → LoadFile RPC\n   (file_path string to DuckDB svc)\n5. DuckDB svc reads CSV/Excel\n   into in-memory table\n6. file_refs row inserted in SQLite\n7. 200 OK → { table_name }",
      "originalText": "1. POST /files/upload (multipart)\n2. JWT middleware validates token\n3. File saved → uploads/{uid}/\n4. FileHandler → LoadFile RPC\n   (file_path string to DuckDB svc)\n5. DuckDB svc reads CSV/Excel\n   into in-memory table\n6. file_refs row inserted in SQLite\n7. 200 OK → { table_name }",
      "fontSize": 11,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "strokeColor": "#22c55e",
      "backgroundColor": "transparent",
