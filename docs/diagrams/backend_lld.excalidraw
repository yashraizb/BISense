    {
      "type": "text",
      "id": "session_flow_legend_title",
      "x": 1012, "y": 572,
      "width": 576, "height": 20,
      "text": "Session + Query Flow",
      "originalText": "Session + Query Flow",
      "fontSize": 13,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "strokeColor": "#93c5fd",
      "backgroundColor": "transparent",
