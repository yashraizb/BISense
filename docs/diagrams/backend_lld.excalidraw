    {
      "type": "text",
      "id": "ws_msg_legend_body",
      "x": 322, "y": 716,
      "width": 306, "height": 310,
      "text": "→ { type: \"query\",\n     session_id, prompt }\n\n← { type: \"status\",\n     message: \"Planning...\" }\n\n← { type: \"query_plan\",\n     steps: [...] }\n\n← { type: \"partial_result\",\n     step: 1, rows: [...] }\n\n← { type: \"final_result\",\n     csv_path, rows: [...] }\n\n← { type: \"error\",\n     code, message }",
      "originalText": "→ { type: \"query\",\n     session_id, prompt }\n\n← { type: \"status\",\n     message: \"Planning...\" }\n\n← { type: \"query_plan\",\n     steps: [...] }\n\n← { type: \"partial_result\",\n     step: 1, rows: [...] }\n\n← { type: \"final_result\",\n     csv_path, rows: [...] }\n\n← { type: \"error\",\n     code, message }",
