      "roughness": 0, "opacity": 100,
      "text": "FileLoader  (LoadFile + ReplaceFile)",
      "originalText": "FileLoader  (LoadFile + ReplaceFile)",
      "fontSize": 16, "fontFamily": 3,
      "textAlign": "left", "verticalAlign": "top",
      "containerId": null, "lineHeight": 1.25,
      "seed": 100035, "version": 1, "versionNonce": 100035,
      "isDeleted": false, "index": "aY",
      "boundElements": [], "updated": 0, "link": null, "locked": false
    },
    {
      "id": "panel2_content",
      "type": "text",
      "x": 615, "y": 795,
      "width": 530, "height": 460,
      "angle": 0,
      "strokeColor": "#374151", "backgroundColor": "transparent",
      "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid",
      "roughness": 0, "opacity": 100,
      "text": "1. validate_file()\n   ├─ type: CSV / XLSX only\n   └─ size: ≤ MAX_FILE_MB\n\n2. copy_to_storage()\n   └─ {STORAGE_ROOT}/{user}/data/{filename}\n\n3. create_table()\n   └─ CREATE TABLE t FROM '{path}'\n      (DuckDB auto-detects CSV/XLSX)\n\n4. export_schema()\n   └─ {filename}.meta.json\n      {col_names, col_types, row_count}\n\n5. update_session_metadata()\n   └─ append FileRecord to session_meta\n\nTimeout: asyncio.wait_for(120s)\nError codes:\n  INVALID_ARGUMENT  — bad type/size\n  INTERNAL          — DuckDB error\n  ALREADY_EXISTS    — use ReplaceFile",
      "originalText": "1. validate_file()\n   ├─ type: CSV / XLSX only\n   └─ size: ≤ MAX_FILE_MB\n\n2. copy_to_storage()\n   └─ {STORAGE_ROOT}/{user}/data/{filename}\n\n3. create_table()\n   └─ CREATE TABLE t FROM '{path}'\n      (DuckDB auto-detects CSV/XLSX)\n\n4. export_schema()\n   └─ {filename}.meta.json\n      {col_names, col_types, row_count}\n\n5. update_session_metadata()\n   └─ append FileRecord to session_meta\n\nTimeout: asyncio.wait_for(120s)\nError codes:\n  INVALID_ARGUMENT  — bad type/size\n  INTERNAL          — DuckDB error\n  ALREADY_EXISTS    — use ReplaceFile",
      "fontSize": 12, "fontFamily": 3,
