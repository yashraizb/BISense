    {
      "id": "storage_text",
      "type": "text",
      "x": 975, "y": 1350,
      "width": 530, "height": 395,
      "angle": 0,
      "strokeColor": "#22c55e", "backgroundColor": "transparent",
      "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid",
      "roughness": 0, "opacity": 100,
      "text": "STORAGE_ROOT/\n└── {user_id}/\n    ├── data/\n    │   ├── sales.csv\n    │   ├── sales.csv.meta.json\n    │   ├── users.xlsx\n    │   └── users.xlsx.meta.json\n    ├── derived/\n    │   ├── q1_summary.csv\n    │   └── monthly_totals.csv\n    └── results/          ← (future)\n        └── {query_id}/\n\ndata/    — original uploaded files\n           reloaded first on resume\n\nderived/ — CREATE TABLE exports\n           reloaded second on resume\n           (preserves derived state)\n\nresults/ — reserved for async\n           query result caching",
      "originalText": "STORAGE_ROOT/\n└── {user_id}/\n    ├── data/\n    │   ├── sales.csv\n    │   ├── sales.csv.meta.json\n    │   ├── users.xlsx\n    │   └── users.xlsx.meta.json\n    ├── derived/\n    │   ├── q1_summary.csv\n    │   └── monthly_totals.csv\n    └── results/          ← (future)\n        └── {query_id}/\n\ndata/    — original uploaded files\n           reloaded first on resume\n\nderived/ — CREATE TABLE exports\n           reloaded second on resume\n           (preserves derived state)\n\nresults/ — reserved for async\n           query result caching",
      "fontSize": 11, "fontFamily": 3,
      "textAlign": "left", "verticalAlign": "top",
