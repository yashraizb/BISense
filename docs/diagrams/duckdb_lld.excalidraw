    {
      "id": "panel3_title",
      "type": "text",
      "x": 1195, "y": 762,
      "width": 530, "height": 26,
      "angle": 0,
      "strokeColor": "#b45309", "backgroundColor": "transparent",
      "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid",
      "roughness": 0, "opacity": 100,
      "text": "SQLGuardrails  (allowlist validation)",
      "originalText": "SQLGuardrails  (allowlist validation)",
      "fontSize": 16, "fontFamily": 3,
      "textAlign": "left", "verticalAlign": "top",
      "containerId": null, "lineHeight": 1.25,
      "seed": 100038, "version": 1, "versionNonce": 100038,
      "isDeleted": false, "index": "b1",
      "boundElements": [], "updated": 0, "link": null, "locked": false
    },
    {
      "id": "panel3_content",
      "type": "text",
      "x": 1195, "y": 795,
      "width": 530, "height": 460,
      "angle": 0,
      "strokeColor": "#374151", "backgroundColor": "transparent",
      "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid",
      "roughness": 0, "opacity": 100,
      "text": "ALLOWED (allowlist):\n  SELECT      — reads only\n  WITH        — CTEs\n  CREATE TABLE— intermediate tables\n  CREATE VIEW — virtual tables\n\nBANNED (any other statement type):\n  DROP  DELETE  ALTER  INSERT\n  UPDATE  TRUNCATE  EXEC  …\n\nvalidate(sql: str) → None\n  raises gRPC INVALID_ARGUMENT\n  if first keyword not in ALLOWED\n\nCREATE TABLE persistence:\n  On connection close / eviction,\n  export each user-created table as:\n  {STORAGE_ROOT}/{user}/derived/{table}.csv\n  → reloaded on session resume",
      "originalText": "ALLOWED (allowlist):\n  SELECT      — reads only\n  WITH        — CTEs\n  CREATE TABLE— intermediate tables\n  CREATE VIEW — virtual tables\n\nBANNED (any other statement type):\n  DROP  DELETE  ALTER  INSERT\n  UPDATE  TRUNCATE  EXEC  …\n\nvalidate(sql: str) → None\n  raises gRPC INVALID_ARGUMENT\n  if first keyword not in ALLOWED\n\nCREATE TABLE persistence:\n  On connection close / eviction,\n  export each user-created table as:\n  {STORAGE_ROOT}/{user}/derived/{table}.csv\n  → reloaded on session resume",
      "fontSize": 12, "fontFamily": 3,
      "textAlign": "left", "verticalAlign": "top",
      "containerId": null, "lineHeight": 1.4,
      "seed": 100039, "version": 1, "versionNonce": 100039,
      "isDeleted": false, "index": "b2",
      "boundElements": [], "updated": 0, "link": null, "locked": false
    },
