    },
    {
      "id": "proto_text",
      "type": "text",
      "x": 35, "y": 1350,
      "width": 890, "height": 395,
      "angle": 0,
      "strokeColor": "#22c55e", "backgroundColor": "transparent",
      "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid",
      "roughness": 0, "opacity": 100,
      "text": "syntax = \"proto3\";\npackage bisense;\n\nservice BISenseDuckDB {\n  rpc LoadFile     (LoadFileRequest)      returns (LoadFileResponse);\n  rpc ExecuteQuery (QueryRequest)         returns (stream QueryResult);\n  rpc ListFiles    (ListFilesRequest)     returns (ListFilesResponse);\n  rpc GetFileInfo  (GetFileInfoRequest)   returns (GetFileInfoResponse);\n  rpc DeleteFile   (DeleteFileRequest)    returns (DeleteFileResponse);\n  rpc ReplaceFile  (ReplaceFileRequest)   returns (ReplaceFileResponse);\n  rpc HealthCheck  (HealthCheckRequest)   returns (HealthCheckResponse);\n}\n\nmessage QueryRequest  { string user_id = 1; string sql = 2; }\nmessage QueryResult   {\n  oneof result {\n    QueryHeader header = 1;\n    QueryRow    row    = 2;\n  }\n}\nmessage QueryHeader   { repeated string col_names = 1;\n                         repeated string col_types = 2; }\nmessage QueryRow      { string json = 1; }\n\nmessage LoadFileRequest  { string user_id = 1; string filename = 2;\n                            bytes  data    = 3; }\nmessage LoadFileResponse { string table_name = 1; int64 row_count = 2;\n                            repeated string col_names = 3;\n                            repeated string col_types = 4; }",
      "originalText": "syntax = \"proto3\";\npackage bisense;\n\nservice BISenseDuckDB {\n  rpc LoadFile     (LoadFileRequest)      returns (LoadFileResponse);\n  rpc ExecuteQuery (QueryRequest)         returns (stream QueryResult);\n  rpc ListFiles    (ListFilesRequest)     returns (ListFilesResponse);\n  rpc GetFileInfo  (GetFileInfoRequest)   returns (GetFileInfoResponse);\n  rpc DeleteFile   (DeleteFileRequest)    returns (DeleteFileResponse);\n  rpc ReplaceFile  (ReplaceFileRequest)   returns (ReplaceFileResponse);\n  rpc HealthCheck  (HealthCheckRequest)   returns (HealthCheckResponse);\n}\n\nmessage QueryRequest  { string user_id = 1; string sql = 2; }\nmessage QueryResult   {\n  oneof result {\n    QueryHeader header = 1;\n    QueryRow    row    = 2;\n  }\n}\nmessage QueryHeader   { repeated string col_names = 1;\n                         repeated string col_types = 2; }\nmessage QueryRow      { string json = 1; }\n\nmessage LoadFileRequest  { string user_id = 1; string filename = 2;\n                            bytes  data    = 3; }\nmessage LoadFileResponse { string table_name = 1; int64 row_count = 2;\n                            repeated string col_names = 3;\n                            repeated string col_types = 4; }",
