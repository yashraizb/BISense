      "text": "bisense.proto",
      "originalText": "bisense.proto",
      "fontSize": 11, "fontFamily": 3,
      "textAlign": "left", "verticalAlign": "top",
      "containerId": null, "lineHeight": 1.25,
      "seed": 100046, "version": 1, "versionNonce": 100046,
